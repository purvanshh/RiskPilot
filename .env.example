# Loan Underwriter Multi-Agent System — Environment Variables
# Copy this to .env and fill in your keys

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (tracing & observability)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="RiskPilot"

# (Optional) LangChain Hub
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_HUB_API_KEY=your_hub_api_key_here

# ---------------------------------------------------------------------------
# RiskPilot Server Configuration
# ---------------------------------------------------------------------------

# Flask server
DEBUG=false
HOST=127.0.0.1
PORT=8501
SECRET_KEY=change-me-to-a-random-secret

# CORS — set to the frontend origin that is allowed to call the API
# ALLOWED_ORIGIN=http://localhost:3000

# Maximum request body size in bytes (default: 1 MB)
MAX_CONTENT_LENGTH=1048576

# API authentication — comma-separated list of valid API keys
# When empty (default), authentication is *disabled* (open to all requests).
# To enable, set at least one key:
# API_KEYS=rp-prod-key-abc123,rp-prod-key-def456
API_KEYS=
